# .env.example — copie para .env e preencha

# ─── IA (Groq — 100% gratuito) ───────────────────────────────────────────────
# Cadastre em: https://console.groq.com
# Crie uma API key e cole aqui
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
# Instância da sua Evolution API
EVOLUTION_URL=https://sua-evolution.onrender.com
EVOLUTION_API_KEY=sua-chave-aqui

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere um token aleatório: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=gere-um-token-aleatorio-aqui
ADMIN_API_KEY=gere-outro-token-aqui

# ─── Configuração da empresa ──────────────────────────────────────────────────
# Conhecimento inicial (pode atualizar via API /api/configure depois)
COMPANY_KNOWLEDGE=Empresa: SuaEmpresa\nProduto: Descreva aqui\nPreços: R$ xxx

# ─── Voz ─────────────────────────────────────────────────────────────────────
# true = sempre responde em áudio / false = só responde em áudio quando cliente mandar áudio
ALWAYS_AUDIO=false
